{
  "name": "llmstack-vscode",
  "displayName": "LLMStack — Local AI",
  "description": "Local-first AI coding assistant. Talks to your own LLMStack gateway — code never leaves your machine.",
  "version": "0.1.0",
  "publisher": "llmstack",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "qna": "https://github.com/mara-werils/llmstack/issues",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "local-ai",
    "ollama",
    "copilot",
    "privacy",
    "llm",
    "offline",
    "code-completion",
    "assistant",
    "self-hosted"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mara-werils/llmstack.git",
    "directory": "editors/vscode"
  },
  "bugs": {
    "url": "https://github.com/mara-werils/llmstack/issues"
  },
  "homepage": "https://github.com/mara-werils/llmstack",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "llmstack.ask",
        "title": "LLMStack: Ask about selection"
      },
      {
        "command": "llmstack.explain",
        "title": "LLMStack: Explain selected code"
      },
      {
        "command": "llmstack.checkHealth",
        "title": "LLMStack: Check gateway health"
      },
      {
        "command": "llmstack.toggleInlineCompletion",
        "title": "LLMStack: Toggle inline code completion"
      },
      {
        "command": "llmstack.editSelection",
        "title": "LLMStack: Edit selection with AI…"
      },
      {
        "command": "llmstack.openChat",
        "title": "LLMStack: Open chat"
      },
      {
        "command": "llmstack.newChat",
        "title": "LLMStack: New chat",
        "icon": "$(add)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "llmstack",
          "title": "LLMStack",
          "icon": "media/llmstack.svg"
        }
      ]
    },
    "views": {
      "llmstack": [
        {
          "type": "webview",
          "id": "llmstack.chatView",
          "name": "Chat"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "llmstack.editSelection",
          "when": "editorHasSelection",
          "group": "llmstack@1"
        },
        {
          "command": "llmstack.explain",
          "when": "editorHasSelection",
          "group": "llmstack@2"
        }
      ],
      "view/title": [
        {
          "command": "llmstack.newChat",
          "when": "view == llmstack.chatView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "llmstack.ask",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "llmstack.editSelection",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "LLMStack",
      "properties": {
        "llmstack.gatewayUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "Base URL of your local LLMStack gateway."
        },
        "llmstack.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the gateway (only needed if gateway.auth=api_key)."
        },
        "llmstack.model": {
          "type": "string",
          "default": "llama3.2",
          "description": "Model name to use for completions."
        },
        "llmstack.inlineCompletion.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Show ghost-text code completions from your local gateway as you type (opt-in)."
        },
        "llmstack.inlineCompletion.contextLines": {
          "type": "number",
          "default": 50,
          "description": "Number of lines of surrounding code to send as context for inline completions."
        },
        "llmstack.inlineCompletion.maxTokens": {
          "type": "number",
          "default": 200,
          "description": "Maximum tokens to generate for a single inline completion."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "package": "vsce package --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "ovsx": "^0.9.0",
    "typescript": "^5.4.0"
  }
}
