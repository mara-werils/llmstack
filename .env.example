# LLMStack Environment Variables
# Copy this file to .env and configure as needed

# ─── Provider API Keys ───────────────────────────────────────────────
# Only needed if using cloud providers via the universal gateway
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=

# ─── Gateway Configuration ───────────────────────────────────────────
# API keys for authenticating gateway requests (comma-separated)
LLMSTACK_API_KEYS=

# Rate limit: requests per window (e.g., "100/min", "1000/hour")
LLMSTACK_RATE_LIMIT=100/min

# CORS origins (comma-separated, default: *)
LLMSTACK_CORS_ORIGINS=*

# ─── Service URLs ────────────────────────────────────────────────────
# These are auto-configured when using 'llmstack up' with Docker
LLMSTACK_INFERENCE_URL=http://localhost:11434/v1
LLMSTACK_QDRANT_URL=http://localhost:6333
LLMSTACK_REDIS_URL=redis://localhost:6379

# ─── Router Configuration ───────────────────────────────────────────
# JSON config for smart model routing (set via llmstack.yaml instead)
# LLMSTACK_ROUTER_CONFIG=

# ─── Provider Configuration ──────────────────────────────────────────
# JSON config for multi-provider setup (set via llmstack.yaml instead)
# LLMSTACK_PROVIDERS_CONFIG=

# ─── Security ────────────────────────────────────────────────────────
# Trusted proxy IPs for X-Forwarded-For header parsing (comma-separated)
LLMSTACK_TRUSTED_PROXIES=

# Maximum request body size in bytes (default: 10MB)
LLMSTACK_MAX_REQUEST_BYTES=10485760

# Enable audit logging for security events (auth failures, rate limits)
LLMSTACK_AUDIT_LOG=true

# ─── Warmup ─────────────────────────────────────────────────────────
# Enable model warm-up on startup (default: true)
LLMSTACK_WARMUP_ENABLED=true

# Warmup concurrency (number of models warmed up simultaneously)
LLMSTACK_WARMUP_CONCURRENCY=3

# ─── Observability ───────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LLMSTACK_LOG_LEVEL=INFO

# Log format: json or text
LLMSTACK_LOG_FORMAT=text
